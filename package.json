{
  "name": "startup-suite-channel-plugin",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Startup-Suite/startup-suite-channel.git"
  },
  "type": "module",
  "description": "OpenClaw channel plugin for Startup Suite federation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "startup-suite",
      "label": "Startup Suite",
      "blurb": "Connect to a Startup Suite deployment as a federated agent runtime"
    }
  },
  "dependencies": {
    "openclaw": "*",
    "phoenix": "^1.7.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
