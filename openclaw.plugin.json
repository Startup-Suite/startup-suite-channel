{
  "id": "startup-suite-channel-plugin",
  "kind": "channel",
  "channels": ["startup-suite"],
  "name": "Startup Suite Channel",
  "description": "Connect to a Startup Suite deployment as a federated agent runtime",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "startup-suite": {
        "type": "object",
        "description": "Multi-account Startup Suite channel config",
        "properties": {
          "accounts": {
            "type": "object",
            "description": "Named agent connections. Each key is an accountId (e.g. 'higgins', 'beacon').",
            "additionalProperties": {
              "type": "object",
              "required": ["url", "runtimeId", "token"],
              "properties": {
                "url": {
                  "type": "string",
                  "description": "Suite WebSocket endpoint URL",
                  "default": "wss://suite.milvenan.technology/runtime/ws"
                },
                "runtimeId": {
                  "type": "string",
                  "description": "Registered runtime ID from Suite"
                },
                "token": {
                  "type": "string",
                  "description": "Authentication token for the runtime"
                },
                "autoJoinSpaces": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Space IDs to automatically join on connect",
                  "default": []
                },
                "reconnectIntervalMs": {
                  "type": "number",
                  "description": "Initial reconnection interval in milliseconds",
                  "default": 5000
                },
                "maxReconnectIntervalMs": {
                  "type": "number",
                  "description": "Maximum reconnection interval in milliseconds",
                  "default": 60000
                },
                "useMcpTools": {
                  "type": "boolean",
                  "description": "Skip the channel-era `suite_*` tool-name hints in agent prompts and emit MCP-compatible guidance instead. Enable this once the agent is wired to Suite's /mcp endpoint for tool execution (ADR 0034).",
                  "default": false
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "channels.startup-suite.accounts": {
      "label": "Agent Accounts",
      "description": "One entry per federated agent. Key = accountId, value = connection config."
    }
  }
}
